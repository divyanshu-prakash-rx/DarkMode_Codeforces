{
  "manifest_version": 3,
  "name": "Codeforces Dark Mode — Multi Theme",
  "version": "1.0.0",
  "description": "Apply beautiful dark themes to Codeforces. 14 themes, persistent across every page until you turn it off.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Codeforces Dark Mode",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "activeTab"],
  "content_scripts": [
    {
      "matches": [
        "*://codeforces.com/*",
        "*://*.codeforces.com/*",
        "*://codeforc.es/*",
        "*://*.codeforc.es/*"
      ],
      "js": ["cf-themes.js", "content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
